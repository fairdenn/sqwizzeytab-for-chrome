{
  "manifest_version": 3,
  "name": "Sqwizzey Tab",
  "description": "Fixed page edit button hover positioning and click behavior.",
  "version": "2.9.73",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "action": {
    "default_title": "Daniil Start",
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage",
    "bookmarks",
    "tabs",
    "favicon",
    "clipboardWrite",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "https://*/",
    "http://*/"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "short_name": "Sqwizzey Tab"
}